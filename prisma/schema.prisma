// DB設計ドリルの初期スキーマ（ドリル1: TODO）。
// ここを書き換えて `npm run db:migrate` するのが練習の基本ループ。
generator client {
  provider = "prisma-client" // Prisma 7 の新ジェネレータ（Rust不要）
  output   = "../src/generated/prisma" // 生成先（node_modules外）。要 prisma generate
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime  @default(now())

  @@index([userId])
}
